# Copy this file to .env and fill in values
# Only variables prefixed with VITE_ are exposed to the browser

# Optional — cloud sync + login (Supabase). If unset, simulasi stay in localStorage only.
# Create a project at https://supabase.com , run SQL in supabase/migrations/001_saved_calculations.sql ,
# enable Email + Google; turn OFF email confirmation (Confirm signup) for instant session (quick login + password signup).
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Optional — random long string so derived auth password is not trivial (production recommended):
# VITE_AUTH_IDENTIFIER_PEPPER=your-long-random-secret
